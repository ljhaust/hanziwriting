/*
 * 小程序全局基础样式。
 *
 * 业务意图：统一页面背景、中文字体栈与盒模型，并重置微信原生按钮的默认
 * 边框与内边距，让各页面卡片和按钮在 WXSS 中以一致的视觉基线渲染。
 * 各页面私有样式位于对应 pages 目录下的 .wxss 文件。
 */
page {
  min-height: 100%;
  color: #111827;
  background: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
}

view,
text,
button,
picker,
canvas {
  box-sizing: border-box;
}

/* 微信原生按钮默认带边框和内边距，全局重置为透明底；具体样式由各页面定义。 */
button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
}

button::after {
  border: 0;
}
