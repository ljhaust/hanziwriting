page {
  min-height: 100%;
  color: #111827;
  background: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
}

view,
text,
button,
picker,
canvas {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
}

button::after {
  border: 0;
}
